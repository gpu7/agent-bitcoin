    {
      "parameters": {
        "jsCode": "const invoice = items[0].json.payment_request || \"\";\n\n// Improved Lightning invoice amount parser\nlet amount = 0;\n\nconst match = invoice.match(/lnbcrt(\\d+)([munp]?)/i);\n\nif (match) {\n  let value = parseInt(match[1], 10);\n  const multiplier = (match[2] || '').toLowerCase();\n\n  switch (multiplier) {\n    case 'm': \n      amount = value * 1000;        // milli = 1,000 sats per unit\n      break;\n    case 'u': \n      amount = value;               // micro = 1 sat per unit\n      break;\n    case 'n': \n      amount = value * 1000;        // nano: 10n = 10 * 1000 millisats? Wait — corrected:\n      // Actually for your invoices: 10n = 1 sat → so we treat 'n' as ×0.1 sat per unit? No.\n      // From real decoder: 10n = 1 sat → so multiplier for 'n' should be value * 0.1? Wait.\n\n      // Corrected based on your working decoder:\n      amount = value * 100;         // This makes 10n = 1,000 millisats = 1 sat\n      break;\n    case 'p': \n      amount = value / 1000;        // pico\n      break;\n    default:  \n      amount = value;               // assume sats if no multiplier\n  }\n}\n\nreturn [{\n  json: {\n    payment_request: invoice,\n    amount: Math.floor(amount),     // ensure integer\n    original_amount: amount\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
