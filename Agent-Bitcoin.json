        "jsCode": "const invoice = items[0].json.payment_request || \"\";\n\n// Better Lightning invoice amount parser\nlet amount = 0;\n\nconst match = invoice.match(/lnbcrt(\\d+)([munp]?)/i);\nif (match) {\n  let value = parseInt(match[1], 10);\n  const multiplier = (match[2] || '').toLowerCase();\n\n  switch (multiplier) {\n    case 'm': amount = value * 1000; break;        // milli\n    case 'u': amount = value; break;               // micro\n    case 'n': amount = Math.floor(value / 1000); break; // nano\n    case 'p': amount = Math.floor(value / 1000000); break; // pico\n    default:  amount = value;                      // assume sats\n  }\n}\n\nreturn [{\n  json: {\n    payment_request: invoice,\n    amount: amount,\n    original_amount: amount\n  }\n}];"
