    {
      "parameters": {
        "jsCode": "const { exec } = require('child_process');\n\nconst paymentRequest = items[0].json.payment_request;\n\nconst cmd = `docker exec lnd-agent-a lncli --network=regtest payinvoice \"${paymentRequest}\" --force`;\n\nreturn new Promise((resolve) => {\n  exec(cmd, (err, stdout, stderr) => {\n    if (err) {\n      resolve([{ json: { error: err.message, stderr } }]);\n    } else if (stderr) {\n      resolve([{ json: { error: stderr } }]);\n    } else {\n      resolve([{ json: { stdout, success: stdout.includes('SUCCEEDED') || stdout.includes('Payment successful') } }]);\n    }\n  });\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,
        96
      ],
      "id": "69016380-693b-4777-a019-0f5dfb87ad06",
      "name": "Pay from Agent-A"
    },
    {
      "parameters": {
        "jsCode": "const lastMessage = items[0].json.messages?.slice(-1)[0]?.content || items[0].json.output || '';\n\ntry {\n  const parsed = JSON.parse(lastMessage);\n  if (parsed.pay === true && Number.isInteger(parsed.amount) && parsed.amount > 0) {\n    return [{ json: { pay: true, amount: parsed.amount, reason: parsed.reason || 'No reason given' } }];\n  }\n} catch (e) {}\n\n// Not a payment decision → pass through original\nreturn [{ json: { pay: false, message: lastMessage } }];"
      },
