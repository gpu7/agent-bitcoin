      "parameters": {
        "jsCode": "const lastMessage = items[0].json.messages?.slice(-1)[0]?.content || items[0].json.output || '';\n\ntry {\n  const parsed = JSON.parse(lastMessage);\n  if (parsed.pay === true && Number.isInteger(parsed.amount) && parsed.amount > 0) {\n    return [{ json: { pay: true, amount: parsed.amount, reason: parsed.reason || 'No reason given' } }];\n  }\n} catch (e) {}\n\n// Not a payment decision → pass through original\nreturn [{ json: { pay: false, message: lastMessage } }];"
      },
