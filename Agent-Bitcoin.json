      "parameters": {
        "jsCode": "const lastMessage = items[0].json.messages?.slice(-1)[0]?.content \n                 || items[0].json.output \n                 || '';\n\ntry {\n  const parsed = JSON.parse(lastMessage);\n  \n  if (parsed.pay === true || parsed.pay === \"true\" || parsed.pay === 1) {\n    const amount = Number(parsed.amount);\n    \n    if (Number.isInteger(amount) && amount >= 1 && amount <= 1000000) {\n      return [{ \n        json: { \n          pay: true,                    // Force real boolean\n          amount: amount, \n          reason: parsed.reason || 'No reason given' \n        } \n      }];\n    } else {\n      return [{ \n        json: { \n          pay: false, \n          amount: amount,\n          reason: parsed.reason || 'No reason given',\n          message: `Payment amount ${amount} sats is outside allowed range (1 to 1,000,000 sats)` \n        } \n      }];\n    }\n  }\n} catch (e) {}\n\n// Not a valid payment decision\nreturn [{ \n  json: { \n    pay: false, \n    message: lastMessage,\n    reason: \"Invalid or missing payment JSON from Agent A\" \n  } \n}];"
      },
