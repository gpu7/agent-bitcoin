    },
    {
      "parameters": {
        "jsCode": "const { exec } = require('child_process');\n\n// Input from previous node (after If True)\nconst amount = items[0].json.amount;\nconst reason = items[0].json.reason || 'Payment from Agent A via Grok';\n\n// Escape quotes in reason to avoid shell injection\nconst escapedReason = reason.replace(/\"/g, '\\\\\"');\n\nconst cmd = `docker exec lnd-agent-b lncli --network=regtest addinvoice --amt ${amount} --memo \"${escapedReason}\"`;\n\nreturn new Promise((resolve) => {\n  exec(cmd, (err, stdout, stderr) => {\n    if (err) {\n      console.error('Exec error:', err);\n      resolve([{ json: { error: err.message, stderr } }]);\n    } else if (stderr && !stderr.includes('success')) {\n      console.error('stderr:', stderr);\n      resolve([{ json: { error: stderr } }]);\n    } else {\n      try {\n        const output = JSON.parse(stdout);\n        if (output.payment_request) {\n          resolve([{ json: { payment_request: output.payment_request } }]);\n        } else {\n          resolve([{ json: { error: 'No payment_request in output', stdout } }]);\n        }\n      } catch (parseErr) {\n        resolve([{ json: { error: parseErr.message, stdout } }]);\n      }\n    }\n  });\n});"
      },
