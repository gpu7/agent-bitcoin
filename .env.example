# Create this file: .env.example
# Agent-Bitcoin SDK Configuration

# Container names (for Docker-based regtest)
CONTAINER_PAYMENT_DECISION=agent-payment-decision-lnd
CONTAINER_BITCOIN=agent-bitcoin-lnd

# Macaroon paths (on your host machine)
MACAROON_PAYMENT_DECISION=/tmp/agent-payment-decision.macaroon
MACAROON_BITCOIN=/tmp/agent-bitcoin.macaroon

# Optional: Lightning node host if not using Docker
# LND_HOST=localhost
# LND_PORT=10009
